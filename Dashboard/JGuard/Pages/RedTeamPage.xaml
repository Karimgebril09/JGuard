<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="JGuard.Pages.RedTeamPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:JGuard.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    RequestedTheme="Dark">

    <Grid Background="#020617" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20" Spacing="4">
            <TextBlock Text="Red Team Dashboard" Style="{StaticResource HeaderTextBlockStyle}" Foreground="#FF2D55" FontWeight="Bold"/>
            <TextBlock Text="Configure and execute automated adversarial vulnerability testing on target AI systems." Style="{StaticResource BodyTextBlockStyle}" Foreground="#94A3B8"/>
        </StackPanel>

        <!-- Main Workspace -->
        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left column: Configuration Panel -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">
                    
                    <!-- Attack Strategy Section -->
                    <Border Background="#111827" BorderBrush="#14FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7E8;" Foreground="#FF2D55" FontSize="18"/>
                                <TextBlock Text="Attack Strategy" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Pivot x:Name="StrategyPivot" SelectionChanged="StrategyPivot_SelectionChanged">
                                <!-- Tab 1: Tool-Based -->
                                <PivotItem Header="Tool-Based">
                                    <StackPanel Spacing="10" Margin="0,10,0,0">
                                        <TextBlock Text="Execute preset suites using industry-standard red-teaming frameworks:" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap"/>
                                        <ComboBox x:Name="ComboTool" HorizontalAlignment="Stretch" SelectedIndex="0">
                                            <ComboBoxItem Content="promptfoo (LLM evaluation &amp; security bench)"/>
                                            <ComboBoxItem Content="garak (LLM vulnerability scanner)"/>
                                            <ComboBoxItem Content="deepteam (advanced reinforcement jailbreak)"/>
                                        </ComboBox>
                                    </StackPanel>
                                </PivotItem>

                                <!-- Tab 2: Custom ATJ -->
                                <PivotItem Header="Custom ATJ">
                                    <StackPanel Spacing="10" Margin="0,10,0,0">
                                        <TextBlock Text="Automated Attacker-Target-Judge framework loop:" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap"/>
                                        
                                        <!-- Attacker config -->
                                        <TextBlock Text="Attacker Model" FontSize="11" FontWeight="Bold" Foreground="#FF2D55"/>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="ComboAttackerProvider" HorizontalAlignment="Stretch" SelectedIndex="0">
                                                <ComboBoxItem Content="OpenAI"/>
                                                <ComboBoxItem Content="Gemini"/>
                                                <ComboBoxItem Content="Ollama"/>
                                                <ComboBoxItem Content="Custom API"/>
                                            </ComboBox>
                                            <TextBox Grid.Column="1" x:Name="TextAttackerModel" PlaceholderText="model name (e.g. gpt-4o-mini)"/>
                                        </Grid>

                                        <!-- Target config -->
                                        <TextBlock Text="Target Model (Evaluating)" FontSize="11" FontWeight="Bold" Foreground="#FF2D55"/>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="ComboTargetProvider" HorizontalAlignment="Stretch" SelectedIndex="1">
                                                <ComboBoxItem Content="OpenAI"/>
                                                <ComboBoxItem Content="Gemini"/>
                                                <ComboBoxItem Content="Ollama"/>
                                                <ComboBoxItem Content="Custom API"/>
                                            </ComboBox>
                                            <TextBox Grid.Column="1" x:Name="TextTargetModel" PlaceholderText="model name"/>
                                        </Grid>

                                        <!-- Judge config -->
                                        <TextBlock Text="Judge Model (Evaluates outcome)" FontSize="11" FontWeight="Bold" Foreground="#FFB800"/>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="ComboJudgeProvider" HorizontalAlignment="Stretch" SelectedIndex="0">
                                                <ComboBoxItem Content="OpenAI"/>
                                                <ComboBoxItem Content="Gemini"/>
                                                <ComboBoxItem Content="Ollama"/>
                                                <ComboBoxItem Content="Custom API"/>
                                            </ComboBox>
                                            <TextBox Grid.Column="1" x:Name="TextJudgeModel" PlaceholderText="model name"/>
                                        </Grid>
                                    </StackPanel>
                                </PivotItem>
                            </Pivot>
                        </StackPanel>
                    </Border>

                    <!-- Adversarial Testing Options -->
                    <Border Background="#111827" BorderBrush="#14FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE811;" Foreground="#FFB800" FontSize="18"/>
                                <TextBlock Text="Adversarial Testing Layers" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Inject custom mutations and behaviors into red-team prompts:" FontSize="12" Foreground="#94A3B8"/>

                            <MenuFlyoutSeparator Background="#19FFFFFF"/>

                            <!-- Obfuscation Layer -->
                            <StackPanel Spacing="4">
                                <CheckBox x:Name="CheckObfuscationLayer" Content="Obfuscation Layer" IsChecked="True"/>
                                <Grid ColumnSpacing="12" Margin="24,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Intensity:" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="SliderObfuscation" Minimum="1" Maximum="10" Value="5" Height="32"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind SliderObfuscation.Value, Mode=OneWay}" FontSize="11" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <!-- Multi-Turn Layer -->
                            <StackPanel Spacing="4">
                                <CheckBox x:Name="CheckMultiTurnLayer" Content="Multi-Turn Layer"/>
                                <Grid ColumnSpacing="12" Margin="24,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Turn Count:" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    <NumberBox Grid.Column="1" x:Name="NumMultiTurnTurns" Value="5" Minimum="2" Maximum="20" SpinButtonPlacementMode="Compact" SmallChange="1" HorizontalAlignment="Left" Width="100"/>
                                </Grid>
                            </StackPanel>

                            <!-- Roleplaying Layer -->
                            <StackPanel Spacing="4">
                                <CheckBox x:Name="CheckRoleplayLayer" Content="Roleplaying Layer" IsChecked="True"/>
                                <Grid ColumnSpacing="12" Margin="24,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Persona template:" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" x:Name="ComboPersona" SelectedIndex="0" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Pretend Coder (Unrestricted environment)"/>
                                        <ComboBoxItem Content="DAN Mode v9.2 (Unconstrained responses)"/>
                                        <ComboBoxItem Content="Opposite Roleplay (Reversed ethical policy)"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right column: Execution Console -->
            <Grid Grid.Column="1" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Status & Action Bar -->
                <Border Grid.Row="0" Background="#111827" BorderBrush="#14FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Attack Controller" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TextControllerStatus" Text="Ready to initialize adversarial assessment run." FontSize="12" Foreground="#94A3B8"/>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="BtnLaunch" Content="Launch Red Team Campaign" Click="BtnLaunch_Click" Style="{StaticResource AccentButtonStyle}" Background="#FF2D55" BorderThickness="0" CornerRadius="6" Padding="16,10" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Console Output Terminal -->
                <Border Grid.Row="1" Background="#0A0F1D" BorderBrush="#14FFFFFF" BorderThickness="1" CornerRadius="8" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <!-- Terminal Titlebar -->
                        <Grid Grid.Row="0" Padding="0,0,0,8" BorderBrush="#19FFFFFF" BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="10" Height="10" Fill="#FF2D55"/>
                                <Ellipse Width="10" Height="10" Fill="#FFB800"/>
                                <Ellipse Width="10" Height="10" Fill="#22FF88"/>
                                <TextBlock Text="JGUARD ADVERSARIAL TELEMETRY FEED" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                            <ProgressRing Grid.Column="1" x:Name="TerminalProgressRing" IsActive="False" Width="16" Height="16" Foreground="#FF2D55"/>
                        </Grid>
                        <!-- Console Output logs -->
                        <ScrollViewer Grid.Row="1" x:Name="ConsoleScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,8,0,0">
                            <TextBox x:Name="TextTerminalLog" 
                                     Text="[SYSTEM] Dashboard loaded. Awaiting adversarial trigger sequence..." 
                                     FontFamily="Consolas" FontSize="12" Foreground="#22FF88" 
                                     Background="Transparent" BorderThickness="0" 
                                     IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Progress and Result Panel -->
                <StackPanel Grid.Row="2" Spacing="8">
                    <!-- Progress bar -->
                    <ProgressBar x:Name="AttackProgressBar" Value="0" Maximum="100" Height="8" CornerRadius="4" Foreground="#FF2D55" Background="#111827"/>
                    
                    <!-- Run Result Card (Initially Collapsed) -->
                    <Border x:Name="CardSummary" Background="#111827" BorderBrush="#22FF88" BorderThickness="1.5" CornerRadius="8" Padding="16" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Campaign Execution Completed Successfully" FontSize="15" FontWeight="Bold" Foreground="#22FF88"/>
                                <TextBlock x:Name="TextSummaryMetrics" Text="Vulnerabilities: 4 Critical, 2 High. Average model success rate: 42.5%" FontSize="12" Foreground="#94A3B8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Run ID: " FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TextSummaryId" Text="RUN-009" FontSize="12" FontWeight="Bold" Foreground="#FF2D55" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
