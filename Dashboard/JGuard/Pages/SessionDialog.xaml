<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="JGuard.Pages.SessionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    RequestedTheme="Dark"
    Title="Session Manager"
    PrimaryButtonText="Continue"
    SecondaryButtonText="Cancel"
    DefaultButton="Primary"
    MinWidth="600">

    <Grid>
        <ScrollViewer x:Name="MainContent">
            <StackPanel Spacing="16" Padding="16" HorizontalAlignment="Stretch">
                <!-- Instructions -->
                <TextBlock Text="Choose an existing session or create a new one" FontSize="14" Foreground="#94A3B8" TextWrapping="Wrap"/>
                
                <!-- Existing Sessions Section -->
                <StackPanel Spacing="8" HorizontalAlignment="Stretch">
                    <TextBlock Text="Existing Sessions" FontSize="12" FontWeight="SemiBold" Foreground="#05D9E8"/>
                    <ListBox x:Name="SessionsListBox" MaxHeight="350" SelectionMode="Single" 
                             HorizontalAlignment="Stretch" 
                             HorizontalContentAlignment="Stretch"
                             Padding="0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,4"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="local1:Session" xmlns:local1="using:JGuard.Models">
                                <Border Background="#1E293B" Padding="16" CornerRadius="8" 
                                        BorderBrush="#334155" BorderThickness="1" 
                                        HorizontalAlignment="Stretch">
                                    <Grid RowSpacing="12" HorizontalAlignment="Stretch">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Header: Model and Mode -->
                                        <Grid Grid.Row="0" HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{x:Bind Config.LlmType}" FontWeight="Bold" Foreground="#05D9E8" FontSize="16" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Background="#0F172A" CornerRadius="4" Padding="8,4" VerticalAlignment="Center" BorderBrush="#334155" BorderThickness="1">
                                                <TextBlock Text="{x:Bind Config.ModeText}" FontSize="10" Foreground="#F5F5F5" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>

                                        <!-- Details: Source and Time -->
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE946;" FontSize="11" Foreground="#94A3B8"/>
                                                <TextBlock Text="{x:Bind Config.SourceText}" FontSize="11" Foreground="#94A3B8"/>
                                            </StackPanel>
                                            <TextBlock Text="|" Foreground="#334155" FontSize="11" VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE823;" FontSize="11" Foreground="#94A3B8"/>
                                                <TextBlock Text="{x:Bind LastActive}" FontSize="11" Foreground="#94A3B8"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Protections Badges -->
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                                            <Border CornerRadius="12" Padding="10,3" Background="#064E3B" BorderBrush="#10B981" BorderThickness="1" 
                                                    Visibility="{x:Bind Config.ObfuscationVisibility}">
                                                <TextBlock Text="Obfuscation" FontSize="10" Foreground="#ECFDF5"/>
                                            </Border>
                                            <Border CornerRadius="12" Padding="10,3" Background="#064E3B" BorderBrush="#10B981" BorderThickness="1" 
                                                    Visibility="{x:Bind Config.MultiTurnVisibility}">
                                                <TextBlock Text="Multi-Turn" FontSize="10" Foreground="#ECFDF5"/>
                                            </Border>
                                            <Border CornerRadius="12" Padding="10,3" Background="#064E3B" BorderBrush="#10B981" BorderThickness="1" 
                                                    Visibility="{x:Bind Config.RoleplayVisibility}">
                                                <TextBlock Text="Roleplay" FontSize="10" Foreground="#ECFDF5"/>
                                            </Border>
                                            <Border CornerRadius="12" Padding="10,3" Background="#064E3B" BorderBrush="#10B981" BorderThickness="1" 
                                                    Visibility="{x:Bind Config.PiiVisibility}">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="PII:" FontSize="10" Foreground="#ECFDF5"/>
                                                    <TextBlock Text="{x:Bind Config.PiiStrategy}" FontSize="10" Foreground="#A7F3D0" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                            
                                            <!-- Placeholder if no defenses enabled -->
                                            <TextBlock Text="No defenses active" FontSize="10" Foreground="#64748B" FontStyle="Italic"
                                                       Visibility="{x:Bind Config.NoDefensesVisibility}" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- ID Footer -->
                                        <TextBlock Grid.Row="3" Text="{x:Bind SessionId}" FontSize="9" Foreground="#475569" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button x:Name="DeleteSessionButton" Content="Delete Selected" HorizontalAlignment="Right" FontSize="11" Click="DeleteSessionButton_Click" Visibility="Collapsed" Background="#DC2626" Foreground="#FFFFFF" BorderBrush="#991B1B"/>
                </StackPanel>

                <!-- Divider -->
                <TextBlock Text="— OR —" HorizontalAlignment="Center" Foreground="#64748B" FontSize="12"/>

                <!-- New Session Section -->
                <StackPanel Spacing="12" Padding="12" Background="#1E293B" CornerRadius="8">
                    <TextBlock Text="Create New Session" FontSize="12" FontWeight="SemiBold" Foreground="#05D9E8"/>
                    
                    <!-- Chat Mode -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Chat Mode" FontSize="11" Foreground="#94A3B8"/>
                        <ComboBox x:Name="ChatModeCombo" SelectedIndex="0">
                            <ComboBoxItem>Foundational</ComboBoxItem>
                            <ComboBoxItem>Agent</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <!-- LLM Source -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="LLM Source" FontSize="11" Foreground="#94A3B8"/>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <RadioButton x:Name="RadioOpenSource" Content="Local (Ollama)" Foreground="#F5F5F5"/>
                            <RadioButton x:Name="RadioClosedSource" Content="Closed Source API" Foreground="#F5F5F5"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- LLM Type -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="LLM Model" FontSize="11" Foreground="#94A3B8"/>
                        <TextBox x:Name="LLMTypeBox" PlaceholderText="e.g., qwen2.5:3b-instruct"/>
                    </StackPanel>

                    <!-- API Key (shown only for closed source) -->
                    <StackPanel x:Name="ApiKeyPanel" Spacing="4" Visibility="Collapsed">
                        <TextBlock Text="API Key" FontSize="11" Foreground="#94A3B8"/>
                        <PasswordBox x:Name="ApiKeyBox" PlaceholderText="Enter your API key"/>
                    </StackPanel>

                    <!-- Defenses -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Defenses" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox x:Name="ObfuscationCheck" Content="Obfuscation" Foreground="#F5F5F5"/>
                            <CheckBox x:Name="MultiTurnCheck" Content="Multi-Turn" Foreground="#F5F5F5"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox x:Name="RoleplayCheck" Content="Roleplay" Foreground="#F5F5F5"/>
                            <CheckBox x:Name="PiiCheck" Content="PII Protection" Foreground="#F5F5F5"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- PII Strategy -->
                    <StackPanel x:Name="PiiStrategyPanel" Spacing="4" Visibility="Collapsed">
                        <TextBlock Text="PII Strategy" FontSize="11" Foreground="#94A3B8"/>
                        <ComboBox x:Name="PiiStrategyCombo" SelectedIndex="0">
                            <ComboBoxItem>Mask</ComboBoxItem>
                            <ComboBoxItem>Encrypt</ComboBoxItem>
                            <ComboBoxItem>Block</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <StackPanel x:Name="LoadingOverlay" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
            <ProgressRing IsActive="True" Width="60" Height="60" Foreground="#05D9E8"/>
            <TextBlock Text="Preparing session... This may take a moment." Foreground="#05D9E8" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</ContentDialog>
